{
  "name": "@gkucmierz/utils",
  "version": "2.0.2",
  "type": "module",
  "description": "Usefull functions for solving programming tasks",
  "keywords": [
    "algorithms",
    "array-histogram",
    "base64",
    "bijective",
    "binary-search",
    "combinations",
    "competitive-programming",
    "data-structures",
    "factors",
    "gcd",
    "gray-code",
    "heap",
    "iterator",
    "javascript",
    "lcm",
    "math",
    "memoize",
    "mod",
    "n-choose-k",
    "node",
    "non-blocking",
    "number-theory",
    "permutations",
    "phi",
    "pow-mod",
    "range-array",
    "square-root",
    "tonelli-shanks",
    "trie",
    "utils"
  ],
  "files": [
    "main.mjs",
    "src/"
  ],
  "main": "main.mjs",
  "scripts": {
    "test": "jasmine",
    "watch": "nodemon --exec 'npm test'",
    "docs": "npm run docs:build; npm run docs:open",
    "build:main": "node scripts/generate_main.mjs",
    "docs:build": "jsdoc -c jsdoc.json && cp -r docs/@gkucmierz/utils/*/* docs/ && rm -rf docs/@gkucmierz",
    "docs:open": "open docs/index.html",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitea.7u.pl/gkucmierz/utils.git"
  },
  "author": "Grzegorz Kućmierz",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "docdash": "^2.0.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^8.0.3",
    "jasmine": "^4.4.0",
    "jsdoc": "^4.0.4",
    "nodemon": "^3.1.14"
  }
}
