{
  "source": {
    "include": ["src"],
    "includePattern": ".+\\.(js(doc|x)?|mjs)$"
  },
  "opts": {
    "destination": "./docs/",
    "template": "node_modules/docdash",
    "package": "package.json",
    "readme": "README.md"
  },
  "docdash": {
    "static": true,
    "sort": true,
    "search": true,
    "collapse": true,
    "meta": {
      "title": "@gkucmierz/utils Developer API"
    }
  }
}
